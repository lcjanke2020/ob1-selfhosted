# Secrets — never commit environment files
.env
*.env
!.env.example

# Editor / OS noise
.idea/
.vscode/
.DS_Store

# Local scratch (anything here stays out of the repo)
local_dont_track/

# Backups and exports
*.sql.gz
*.dump

# Pre-commit leak guard: real hostname/string denylist stays local.
# The .example template is tracked; the live list is not.
.leak-denylist
