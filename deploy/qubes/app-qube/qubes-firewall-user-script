#!/bin/sh
# App qube host firewall — scope the published mcp port (:8787) to the ingress
# qube ONLY.
#
# Install at: /rw/config/qubes-firewall-user-script   (chmod +x)
#
# WHY DOCKER-USER, not the Qubes custom-input chain:
# docker-compose.yml publishes mcp on 0.0.0.0:8787, i.e. ALL interfaces
# (tailnet AND the LAN-facing eth0). docker installs DNAT rules in the nat table
# that redirect that traffic to the container BEFORE the Qubes `ip qubes
# custom-input` chain sees it — so a `custom-input` accept/drop never matches
# the published-port traffic. The user-facing hook docker leaves for exactly
# this is the DOCKER-USER chain (traversed in FORWARD for container-bound
# traffic). That is where the scoping rule must live.
#
# This is the host-firewall layer — one of the three independent layers that
# scope the wide bind (Tailscale ACL + this rule + mcp app auth). It also closes
# the LAN-reachable-bind gap: because we DROP :8787 on every source except the
# one ingress IP (not just on tailscale0), an eth0/LAN client cannot reach the
# port either.
#
# >>> EDIT THIS: the ingress qube's tailnet IP (the only peer allowed to reach
#     mcp). IPv4 (Tailscale CGNAT, 100.64/10) or IPv6 (fd7a:…) — set whichever
#     address the ingress qube's Caddy uses as MCP_UPSTREAM. Leave the other
#     family fully dropped (the default below).
INGRESS_IP="<ingress-qube-tailnet-ip>"
PORT=8787
LOG=/var/log/ob1-app-firewall.log

# Docker SEEDS DOCKER-USER with a trailing `-j RETURN`, so the chain is NOT
# empty: rules must be INSERTED (-I) to sit ABOVE that RETURN. An APPENDED (-A)
# rule lands below the RETURN and never executes — traversal returns to FORWARD
# first (this is the bug this script must not have: it would log "added" while
# leaving :8787 wide open). See Docker's "Docker and iptables" docs.
#
# Idempotent rebuild: delete any existing copy of the exact rule first (so a
# re-run can't stack duplicates and the final order is guaranteed), then insert
# at the top. Because each call re-inserts at the top, the LAST call wins the top
# slot — so we insert the DROP(s) first and the ingress ACCEPT last, leaving:
#   ACCEPT (ingress peer)  ──┐ top
#   DROP   (catch-all :8787) │  both ABOVE docker's RETURN
#   RETURN (docker's)      ──┘
ensure_top() {
	fam=$1; shift
	while "$fam" -C DOCKER-USER "$@" 2>/dev/null; do
		"$fam" -D DOCKER-USER "$@" 2>>"$LOG" || break
	done
	if "$fam" -I DOCKER-USER "$@" 2>>"$LOG"; then
		echo "$(date -Is) [$fam] inserted: $*" >>"$LOG"
	else
		echo "$(date -Is) [$fam] FAILED to insert (DOCKER-USER missing? is docker up?): $*" >>"$LOG"
	fi
}

# Pick the iptables family for the allow rule from the configured IP. The DROP
# is applied on BOTH families so the unconfigured family is fully closed.
case "$INGRESS_IP" in
	*:*) ALLOW_FAM=ip6tables ;;
	*)   ALLOW_FAM=iptables ;;
esac

# DROP(s) first so the ACCEPT inserted afterwards lands ABOVE them. The DROP is
# intentionally NOT conntrack-qualified: unlike the db-qube's nft rule (which
# rides a chain that already has a general established-accept), DOCKER-USER has
# none — so the ACCEPT must cover the whole allowed flow and the DROP must catch
# every non-ingress packet to :8787 regardless of ct state.
ensure_top iptables  -p tcp --dport "$PORT" -j DROP
ensure_top ip6tables -p tcp --dport "$PORT" -j DROP

# ...then the ingress-peer ACCEPT, which ends up on top (above the DROP).
# NOTE: rotating INGRESS_IP leaves the OLD address's ACCEPT behind (a different
# spec, so the delete above never matches it). After changing INGRESS_IP, flush
# the chain and re-run — `iptables -F DOCKER-USER && /rw/config/qubes-firewall-user-script`
# (docker re-adds its own RETURN) — or just reboot.
ensure_top "$ALLOW_FAM" -i tailscale0 -s "$INGRESS_IP" -p tcp --dport "$PORT" -j ACCEPT

# Always succeed: this script also runs as a docker.service ExecStartPost (see
# docker-ob1-firewall.conf), and a non-zero exit there would fail docker's start.
# Rule-add failures are logged above, not propagated.
exit 0
