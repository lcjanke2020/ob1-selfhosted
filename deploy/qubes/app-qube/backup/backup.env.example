# Backup job config — copy to backup.env and fill in.
#   cp backup.env.example backup.env && $EDITOR backup.env
#
# Sourced in isolation by ob1-db-backup.sh (NOT the compose .env) so only these
# few vars — not every secret in the deploy env — reach pg_dump's child process.
# Install the filled-in copy at /rw/config/openbrain-units/backup.env.

# The db qube (canonical Postgres). Same address as DB_HOST in the app .env.
DB_HOST=<db-qube-tailnet-ip>
DB_PORT=5432
POSTGRES_DB=openbrain

# READ-ONLY role used for the dump (least privilege — a backup needs SELECT, not
# the app or admin role). Must be permitted from this qube's IP in the db qube's
# pg_hba (openbrain_readonly host line).
READONLY_ROLE=openbrain_readonly
READONLY_PASSWORD=

# PUBLIC key only (encrypt-only host; the private key lives on a separate
# restore machine). Move it here with a binary-safe transport, not chat/email.
PUBKEY=/rw/config/openbrain-units/backup-pubkey.asc

# Off-box-replicated output directory (a Syncthing send folder to an off-box
# host that holds the private key). Add
# `/.db-*` to this folder's .stignore so peers never sync the staging temp.
OUT_DIR=/home/openbrain/sync/ob1-db-backups

# Days to keep encrypted dumps before pruning (default 14).
RETAIN_DAYS=14
