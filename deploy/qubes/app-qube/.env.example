# app qube .env — copy to .env and fill in.
#   cp .env.example .env && $EDITOR .env
#
# This is the per-qube credential split for the APP qube of the three-qube
# topology. The app qube is the trusted compartment and DB control-plane, so it
# DOES hold the admin/superuser password (unlike the internet-adjacent ingress
# qube, which holds only the INSERT-only ingester credential). It never holds
# the ingester credential.

# ---------- Database (canonical Postgres on the dedicated DB qube) ----------

# Database name (default openbrain).
POSTGRES_DB=openbrain

# The canonical Postgres lives on the dedicated DB qube. MANDATORY here — this
# qube runs no local postgres. Set to the db qube's tailnet address.
#   DB_HOST=<db-qube-tailnet-ip>
DB_HOST=
DB_PORT=5432

# Admin/superuser password for the db qube's cluster, held on this qube (the
# trusted compartment — never on the internet-adjacent ingress qube) and used to
# administer the db qube REMOTELY over the tailnet: role provisioning +
# schema/migrations (db/00-roles.sh, db/01-schema.sql,
# scripts/upgrade-add-ingester-role.sh). The db-qube pg_hba grants the superuser
# a host line from THIS qube's IP only — a deliberate trade-off (see
# deploy/qubes/db-qube/). mcp does NOT connect as this user; it uses openbrain_app.
# generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# Application role the MCP server connects as — SELECT/INSERT/UPDATE on
# public.thoughts only. This is the role that "writes thoughts."
# generate: openssl rand -hex 24
OPENBRAIN_APP_PASSWORD=

# Read-only role (SELECT only). Used by the encrypted backup job in backup/
# (pg_dump against the db qube) and for ad-hoc inspection.
# generate: openssl rand -hex 24
OPENBRAIN_READONLY_PASSWORD=

# NOTE: there is intentionally no OPENBRAIN_INGESTER_PASSWORD here — the
# log-ingester runs on the ingress qube, which is the only qube that holds it.

# ---------- Embeddings (Ollama, CPU-only in this qube) ---------------------

# Local in-compose ollama by default. Point at an external GPU box to offload:
#   OLLAMA_URL=http://gpubox.tailnet-name.ts.net:11434
OLLAMA_URL=http://ollama:11434

# nomic-embed-text → 768. mxbai-embed-large → 1024. If you change this, also
# update vector(N) in db/01-schema.sql to match (re-run on the db qube).
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ---------- Optional: metadata extraction via chat LLM ---------------------
# Any OpenAI-compatible /chat/completions endpoint. Leave blank to disable
# (capture still works; metadata defaults to {topics:[uncategorized]}).
#
# PRIMARY endpoint. To classify on an external GPU box with thought content
# kept on your network, point this at that box's endpoint. A Qubes app qube
# has no GPU, so a common shape is to reach a GPU qube's loopback-only ollama
# via a host-side forwarder on :11434 — set CHAT_API_BASE to the docker
# host-gateway alias (see extra_hosts in docker-compose.yml):
#   CHAT_API_BASE=http://host.docker.internal:11434/v1
#   CHAT_MODEL=<your-served-model>     # CHAT_API_KEY blank for a local ollama
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_MODEL=
# CHAT_TIMEOUT_MS=60000

# FALLBACK endpoint — tried ONLY when the PRIMARY above fails (unreachable,
# error, timeout, or unparseable output), before giving up to the minimal
# stub. Lets a local-first primary degrade to a hosted model instead of losing
# metadata when the GPU box is down. Leave blank to disable.
#   FALLBACK_CHAT_API_BASE=https://api.openai.com/v1
#   FALLBACK_CHAT_MODEL=gpt-5.4-mini
# NOTE: enabling this means thought content CAN leave your network on the
# fallback path — the privacy trade-off for graceful degradation.
FALLBACK_CHAT_API_BASE=
FALLBACK_CHAT_API_KEY=
FALLBACK_CHAT_MODEL=

# ---------- MCP server -----------------------------------------------------

# Shared secret Claude Desktop sends as `x-brain-key` (tailnet path).
# generate: openssl rand -hex 32   (config.ts enforces min length 32 at boot)
MCP_ACCESS_KEY=

# Citation URL base for the search/fetch tools. Optional (informational URL).
#   CITATION_BASE_URL=https://homebox.tailnet-name.ts.net/thoughts
CITATION_BASE_URL=

# ---------- Optional: Auth0 OAuth resource server (Funnel path) ------------
# Leave ALL THREE empty for tailnet-only (x-brain-key). Fill ALL THREE to
# enable the OAuth/Funnel public door (the ingress qube's Caddy fronts it).
# Partial config (1 or 2 of 3) throws at boot. See compose-local/.env.example
# for the full Auth0 dashboard setup notes.
AUTH0_ISSUER=
AUTH0_JWKS_URI=
AUTH0_AUDIENCE=
# JWKS_FETCH_TIMEOUT_MS=10000

# ---------- Optional: mcp tunables (defaults mirror the code) --------------
# OBS_AUTH_EVENTS_ENABLED=true
# OBS_AUTH_EVENTS_MAX_IN_FLIGHT=500
# AUTH_BODY_READ_TIMEOUT_MS=2000

# ---------- Encrypted backup ----------------------------------------------
# The daily encrypted DB backup job has its OWN env file so it can be sourced
# in isolation by the systemd unit — see backup/backup.env.example.
