# Funnel-monitor credentials — install at ~/.config/funnel-monitor.env, chmod 0600.
#   cp funnel-monitor.env.example ~/.config/funnel-monitor.env
#   chmod 0600 ~/.config/funnel-monitor.env && $EDITOR ~/.config/funnel-monitor.env
#
# Read by scripts/funnel_monitor.sh (host-side, NOT compose — deliberately
# separate from this directory's .env so the monitor credential never enters
# a container environment).

# The db qube (canonical Postgres) — same address as DB_HOST in .env.
DB_HOST=<db-qube-tailnet-ip>
DB_PORT=5432
POSTGRES_DB=openbrain

# SELECT-only metadata role (funnel_access_log + mcp_auth_events, nothing
# else — created by db/00-roles.sh when OPENBRAIN_MONITOR_PASSWORD is set, or
# by scripts/upgrade-add-monitor-role.sh on an existing DB). The db qube's
# pg_hba must permit openbrain_monitor from THIS qube's tailnet IP.
# generate: openssl rand -hex 24
OPENBRAIN_MONITOR_PASSWORD=

# Alert threshold for funnel request volume per 5-minute window (default 200).
# VOLUME_THRESHOLD=200
