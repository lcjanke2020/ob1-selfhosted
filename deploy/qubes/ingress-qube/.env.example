# ingress qube .env — copy to .env and fill in.
#   cp .env.example .env && $EDITOR .env
#
# Per-qube credential split for the INGRESS (public-edge) qube. This qube is
# internet-adjacent, so it holds the MINIMUM: the upstream address, the db qube
# address, and the INSERT-only log-ingester credential. It must NOT carry the
# superuser (POSTGRES_PASSWORD) or app (OPENBRAIN_APP_PASSWORD) password — those
# live on the app qube.

# ---------- Caddy upstream (the app qube's mcp) ----------------------------

# MANDATORY. The app qube's tailnet address:8787. Caddy reverse-proxies here
# across the tailnet. Kept in .env, never the committed Caddyfile.
#   MCP_UPSTREAM=<app-qube-tailnet-ip>:8787
MCP_UPSTREAM=

# ---------- Log-ingester → db qube -----------------------------------------

# Database name (default openbrain).
POSTGRES_DB=openbrain

# The db qube (canonical Postgres). The ingester writes funnel_access_log rows
# ACROSS to it. MANDATORY.
#   DB_HOST=<db-qube-tailnet-ip>
DB_HOST=
DB_PORT=5432

# INSERT-only observability role — the only DB credential in this compose
# .env (the host-side funnel monitor keeps its SELECT-only credential in
# ~/.config/funnel-monitor.env instead — see funnel-monitor.env.example).
# Required (compose fails to start the ingester without it). The db qube's
# pg_hba must permit openbrain_ingester from THIS qube's tailnet IP.
# generate: openssl rand -hex 24
OPENBRAIN_INGESTER_PASSWORD=

# How often the ingester polls the Caddy access logs (ms, default 5000).
# INGESTER_POLL_INTERVAL_MS=5000

# ---------- Funnel wiring (host, not compose) ------------------------------
# After `docker compose up -d`, expose Caddy publicly with a single rule:
#   sudo tailscale serve  --https=443 off                          # vacate :443
#   sudo tailscale funnel --bg --https=443 http://127.0.0.1:9787   # single rule
# Funnel must also be enabled for this device in the Tailscale admin console.

# ---------- Parked postgres (logs-future profile) --------------------------
# The compose file defines a PARKED local postgres for a future local logs
# store. It is NEVER started by `docker compose up` (profile not activated), so
# leave POSTGRES_PASSWORD / OPENBRAIN_APP_PASSWORD / OPENBRAIN_READONLY_PASSWORD
# UNSET here. Fill them in ONLY if you deliberately activate the `logs-future`
# profile to stand up a local logs database on this qube.
