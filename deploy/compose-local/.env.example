# Copy this file to .env and fill in values.
#   cp .env.example .env
#   $EDITOR .env

# ---------- Postgres -------------------------------------------------------

# Database name (default openbrain).
POSTGRES_DB=openbrain

# Superuser used by the postgres container itself. The MCP server connects
# as openbrain_app, NOT this user.
POSTGRES_USER=postgres
# generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# Application role used by the MCP server. SELECT/INSERT/UPDATE on
# public.thoughts only (no DELETE, no schema-wide DML). The
# observability tables and ingester role are granted
# separately to keep the surface narrow.
# generate: openssl rand -hex 24
OPENBRAIN_APP_PASSWORD=

# Read-only role for direct DB inspection from DBeaver/TablePlus/psql over
# the tailnet. SELECT only on public.*
# generate: openssl rand -hex 24
OPENBRAIN_READONLY_PASSWORD=

# Pattern B observability-only role used by the log-ingester
# sidecar. INSERT-only on funnel_access_log, no access to `thoughts` or
# mcp_auth_events. Leave EMPTY for Pattern A (00-roles.sh skips role
# creation; the ingester service is profile-gated to pattern-b anyway).
# Required for Pattern B — compose will fail to start the ingester
# without it.
# generate: openssl rand -hex 24
OPENBRAIN_INGESTER_PASSWORD=

# ---------- Embeddings (Ollama) -------------------------------------------

# If you're running Ollama in this stack (the default ollama service), leave
# OLLAMA_URL pointing at the service name. If you're using an Ollama on
# another tailnet box, set this to e.g. http://gpubox.tailnet-name.ts.net:11434
OLLAMA_URL=http://ollama:11434

# nomic-embed-text → 768. mxbai-embed-large → 1024. If you change this,
# also update vector(N) in db/01-schema.sql to match.
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ---------- Optional: metadata extraction via chat LLM ---------------------

# Set these to enable automatic extraction of topics/people/action_items/type
# from each captured thought. Any OpenAI-compatible /chat/completions endpoint.
# Examples:
#   Local Ollama: CHAT_API_BASE=http://ollama:11434/v1, CHAT_MODEL=llama3.1:8b
#   OpenRouter:   CHAT_API_BASE=https://openrouter.ai/api/v1, CHAT_MODEL=openai/gpt-4o-mini
#   Leave blank:  capture still works, metadata defaults to {topics:[uncategorized], type:observation}
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_MODEL=

# Wall-clock cap (milliseconds) for the metadata-extraction chat call.
# Separate from the embedding timeout (FETCH_TIMEOUT_MS) — a chat completion
# over a large thought on a slow local model can take far longer than an
# embed. Default 60000 (60 s).
# CHAT_TIMEOUT_MS=60000

# ---------- MCP Server -----------------------------------------------------

# The shared secret Claude Desktop sends as `x-brain-key`. Keep this safe.
# generate: openssl rand -hex 32
# config.ts enforces minimum length 32 at boot. Weak literals like
# `password`, `dev`, `test` will refuse to start the server.
MCP_ACCESS_KEY=

# Used to mint citation URLs in the ChatGPT-compat search/fetch tools.
# Set to your tailnet hostname, e.g. https://homebox.tailnet-name.ts.net/thoughts
# If left blank the server falls back to a non-resolving placeholder, which is
# fine for personal-recall flows (the URL is informational), but you'll want
# this set if any consumer actually follows the link.
CITATION_BASE_URL=

# ---------- Optional: Auth0 OAuth resource server (Funnel path) ------------

# Leave ALL THREE empty for the simplest tailnet-only deployment (x-brain-key
# is the only auth). Fill ALL THREE in to enable the OAuth/Funnel public
# door — partial config (1 or 2 of 3 set) throws at server boot.
#
# Required setup in the Auth0 dashboard before these will work:
#   1. Tenant Settings → Advanced → enable "Resource Parameter Compatibility
#      Profile" (so Auth0 mints a JWT from the resource param instead of an
#      opaque JWE; otherwise the middleware sees aud-mismatch / opaque-token
#      failures it can't diagnose).
#   2. Create an API. The Identifier MUST match AUTH0_AUDIENCE below
#      byte-for-byte and CANNOT be edited later — a mismatch means
#      recreating the API. Signing algorithm: RS256.
#   3. Create a Regular Web Application client (confidential). Grants:
#      authorization_code + refresh_token. Allowed Callback URLs include
#      both https://claude.ai/api/mcp/auth_callback AND
#      https://claude.com/api/mcp/auth_callback.
#
# AUTH0_ISSUER: your Auth0 tenant URL with trailing slash.
# AUTH0_JWKS_URI: the issuer's standard JWKS endpoint (or set explicitly if
#                 you're behind a custom domain).
# AUTH0_AUDIENCE: the resource URL clients send in `resource` param, which
#                 also matches the API Identifier above.
AUTH0_ISSUER=
AUTH0_JWKS_URI=
AUTH0_AUDIENCE=

# Wall-clock cap on JWKS fetches (milliseconds). Bounds both
# the boot-time reachability probe (which surfaces typo'd AUTH0_JWKS_URI
# at startup instead of at first attacker request) AND every per-request
# JWKS refresh by jose. Default 10000 (10 s) is generous for Auth0's
# globally-distributed JWKS endpoint over a home connection while staying
# short enough that a hung upstream can't pin request slots. Raise only
# if you have evidence of legitimately-slow JWKS responses.
# JWKS_FETCH_TIMEOUT_MS=10000

# ---------- Optional: Pattern B compose invocation -------------------------

# Pattern A operators (Auth0 above empty): leave these unset. From
# deploy/compose-local, `docker compose up -d` starts postgres + mcp +
# ollama; caddy is gated by the pattern-b profile and won't start; mcp's
# host port stays published for direct smoke tests.
#
# Pattern B operators (Auth0 above set): copy this file to
# deploy/compose-tailnet/.env instead, and uncomment both lines below so a
# bare `docker compose up -d` run from deploy/compose-tailnet (a) loads
# docker-compose.pattern-b.yml which removes mcp's host port mapping and
# (b) activates the pattern-b profile which starts caddy. The raw mcp
# port is then unreachable from the host — caddy is the only entry point.
# Prevents the Caddy-bypass footgun of a misconfigured `tailscale funnel`
# targeting 127.0.0.1:8787.
#
# Alternative without setting these: pass the flags explicitly on every
# `docker compose ...` command, run from deploy/compose-tailnet:
#   docker compose --project-directory . \
#                  -f ../compose-local/docker-compose.yml \
#                  -f docker-compose.pattern-b.yml \
#                  --profile pattern-b up -d
#
# Path separator note: COMPOSE_FILE uses `:` on Linux/macOS and `;` on
# Windows. The line below is the Linux form (matches the deployment-target
# prereq in the README). On Windows, either switch to `;` or also set
# COMPOSE_PATH_SEPARATOR=:.
#
# COMPOSE_FILE=../compose-local/docker-compose.yml:docker-compose.pattern-b.yml
# COMPOSE_PROFILES=pattern-b
#
# Server-side guard against forgetting the override. The
# Pattern B override sets PATTERN_B=true on the mcp container; mcp's
# config.ts refuses to start when AUTH0_* is set but PATTERN_B isn't.
# This catches the half-configured invocation `docker compose
# --profile pattern-b up -d` (without `-f docker-compose.pattern-b.yml`)
# which would leave mcp's host port published and let a misconfigured
# `tailscale funnel` bypass the Caddyfile header-strip boundary. You
# do NOT set PATTERN_B by hand — it's loaded from the override file.

# ---------- Optional: Observability ------------------------------

# How often the log-ingester sidecar polls the Caddy access log files for
# new lines (milliseconds). Default 5000 (5s). Bump if the box is heavily
# loaded and you'd rather batch ingest; lower if you want fresher visibility
# in the funnel_access_log table. Only consulted in Pattern B (the
# log-ingester is profile-gated).
# INGESTER_POLL_INTERVAL_MS=5000

# Set to "false" to disable the mcp server's 401 audit-event emission. Useful
# only for short-term debugging where you want to silence the audit insert
# without rebuilding the image. Default (enabled) is recommended for any
# Pattern B deployment.
# OBS_AUTH_EVENTS_ENABLED=true

# In-flight cap on audit-event inserts. The 401-emit path is
# fire-and-forget via queueMicrotask, so a sustained Funnel-door flood
# could otherwise queue unbounded memory if postgres lags. Default 500
# is generous for normal traffic; tighten via env for adversarial-load
# tests, raise only if a real workload is dropping legitimate events.
# OBS_AUTH_EVENTS_MAX_IN_FLIGHT=500

# Wall-clock cap (milliseconds) on how long the auth-failure path will wait
# for the request body to complete before giving up on JSON-RPC `id`
# extraction. Bounds time the way the 64 KiB internal cap bounds memory —
# together they prevent a slow-trickle client from holding an auth-failed
# request slot open. Default 2000 (2 s); tighten only if Caddy upstream
# isn't already enforcing a body-receive timeout and you have evidence of
# slow-stream auth-fail traffic. Production deployments can typically
# leave this unset.
# AUTH_BODY_READ_TIMEOUT_MS=2000
